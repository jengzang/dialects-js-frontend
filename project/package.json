{
  "name": "vite-project",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.vue --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && bash deploy.sh",
    "deploy:ps": "npm run build && powershell -ExecutionPolicy Bypass -File deploy.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "eslint": "^9.33.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "terser": "^5.46.0",
    "vite": "^7.1.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.20"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "echarts": "^5.6.0",
    "maplibre-gl": "^5.16.0",
    "opencc-js": "^1.0.5",
    "vue-router": "^4.5.1",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "wavesurfer.js": "^7.12.1",
    "xlsx": "^0.18.5"
  }
}
