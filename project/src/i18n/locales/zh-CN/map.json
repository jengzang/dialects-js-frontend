    "helpModal": {
      "title": "自定义数据使用说明",
      "sections": {
        "overview": {
          "title": "先理解这个区块",
          "items": {
            "privateSpace": {
              "label": "私人资料库：",
              "text": "这里的数据只属于你的账号，登录后才能查看与编辑。"
            },
            "mapRendering": {
              "label": "地图呈现：",
              "text": "系统会依据你填写的「特征」分组，并把「值」直接显示在地图点位上。"
            }
          }
        },
        "fieldGuide": {
          "title": "字段怎样理解",
          "items": {
            "feature": {
              "label": "特征：",
              "text": "用来分类与搜索，例如「流摄」、「豪韵」或「昨天」。"
            },
            "value": {
              "label": "值：",
              "text": "地图上真正显示的内容，例如「iu」、「好吃」或「53」。"
            },
            "featureType": {
              "label": "声韵调 / 类别：",
              "text": "给数据一个大类，例如声母、韵母、调值或词汇。"
            },
            "location": {
              "label": "地点简称：",
              "text": "地图上显示的地点名称，建议填你最常用的称呼。"
            },
            "region": {
              "label": "分区：",
              "text": "你的数据集范围或名称，例如「粤语-高阳片」或「2025田调」。"
            }
          },
          "examples": {
            "middleChinese": "建议用法：补充公共地图或字表里尚未收录的地点数据。",
            "personalCorpus": "如果你知道某地的读音或词形，但网站暂未收录，可以在这里自行补入。"
          }
        },
        "customCollection": {
          "title": "建立自己的数据集",
          "intro": "当你想整理个人田调、词汇、地名或任何可上图的信息时，可以这样理解各字段：",
          "items": {
            "region": {
              "label": "分区：",
              "text": "把它当成文件夹名称，例如「2025田调」。"
            },
            "featureType": {
              "label": "声韵调 / 类别：",
              "text": "可留空；若想粗略分类，也可填「词汇」等大类。"
            },
            "feature": {
              "label": "特征：",
              "text": "把它当成搜索键，例如「昨天」、「玩耍」或「止・精组・开口」。"
            },
            "value": {
              "label": "值：",
              "text": "把它当成地图标签，例如「从日」、「嬲」或「ei」。"
            }
          },
          "notes": {
            "scope": "先在分区输入框填入你的数据集名称，之后搜索就能只针对这个数据集。",
            "search": "搜索框查的是「特征」，不是「值」。",
            "display": "「值」会直接显示在地图点上，适合放音值、词形、评分或简短注记。"
          }
        },
        "dailyUsage": {
          "title": "不做方言研究也能用",
          "intro": "这套机制也可以当成私人生活地图，例如美食地图、景点收藏或采访记录。",
          "connectors": {
            "regionToLocation": "可包含多个地点",
            "locationToData": "再给这个地点加标签"
          },
          "cards": {
            "region": {
              "label": "分区 (Region)",
              "text": "相当于文件夹名称",
              "example": "例：我的美食地图"
            },
            "location": {
              "label": "地点 (Location)",
              "text": "相当于店名或地点名",
              "example": "例：老王烧烤"
            },
            "feature": {
              "label": "特征",
              "text": "相当于分类标签（搜索用）",
              "example": "例：评价 / 类型"
            },
            "value": {
              "label": "值",
              "text": "相当于地图上显示的内容",
              "example": "例：好吃 / 烧烤"
            }
          },
          "result": "例如把分区填成「我的美食地图」，再搜索特征「评价」，地图上就会在各店名位置显示你填入的评语。"
        },
        "steps": {
          "title": "新增数据步骤",
          "items": {
            "mode": {
              "label": "1. 选择模式：",
              "text": "「逐条新增」适合精确点选坐标；「批量新增」适合从 Excel 或表格粘贴多条数据。"
            },
            "coordinates": {
              "label": "2. 获取坐标：",
              "text": "在单笔模式下，打开面板后直接点击地图位置即可自动填入经纬度。"
            },
            "save": {
              "label": "3. 提交保存：",
              "text": "确认字段无误后送出，数据就会保存到你的个人资料库。"
            }
          }
        }
      }
    }
  },
